{
  "$id": "https://truecolor.local/schemas/canonical_document.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "pattern": "^artifact:sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "content_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "document_id": {
      "pattern": "^document:sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "ocr_assessment": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "character_count": {
            "minimum": 0,
            "type": "integer"
          },
          "classification": {
            "enum": [
              "OCR_NOT_REQUIRED",
              "OCR_RECOMMENDED",
              "OCR_REQUIRED",
              "UNDETERMINED"
            ]
          },
          "page_number": {
            "minimum": 1,
            "type": "integer"
          },
          "reason_codes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "word_count": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "page_number",
          "classification",
          "reason_codes",
          "character_count",
          "word_count"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "pages": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "character_count": {
            "minimum": 0,
            "type": "integer"
          },
          "height": {
            "type": [
              "number",
              "null"
            ]
          },
          "page_number": {
            "minimum": 1,
            "type": "integer"
          },
          "text": {
            "type": "string"
          },
          "width": {
            "type": [
              "number",
              "null"
            ]
          },
          "word_count": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "page_number",
          "width",
          "height",
          "text",
          "word_count",
          "character_count"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "parser": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "route": {
          "enum": [
            "PDF",
            "XML",
            "HTML",
            "TEXT",
            "MARKDOWN",
            "DOCX",
            "CSV",
            "TSV",
            "XLSX"
          ]
        },
        "version": {
          "const": "1.0.0"
        }
      },
      "required": [
        "name",
        "version",
        "route"
      ],
      "type": "object"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "segments": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "canonical_end": {
            "minimum": 0,
            "type": "integer"
          },
          "canonical_start": {
            "minimum": 0,
            "type": "integer"
          },
          "kind": {
            "enum": [
              "DOCUMENT",
              "PAGE",
              "PARAGRAPH",
              "HEADING",
              "LIST_ITEM",
              "TABLE_TEXT",
              "XML_ELEMENT",
              "TABLE_ROW",
              "TABLE_CELL"
            ]
          },
          "segment_id": {
            "pattern": "^segment:[a-f0-9]{64}$",
            "type": "string"
          },
          "source": {
            "additionalProperties": false,
            "properties": {
              "bbox": {
                "additionalProperties": false,
                "properties": {
                  "x0": {
                    "type": "number"
                  },
                  "x1": {
                    "type": "number"
                  },
                  "y0": {
                    "type": "number"
                  },
                  "y1": {
                    "type": "number"
                  }
                },
                "required": [
                  "x0",
                  "y0",
                  "x1",
                  "y1"
                ],
                "type": [
                  "object",
                  "null"
                ]
              },
              "cell_reference": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "column_index": {
                "minimum": 1,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "document_part": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "page_number": {
                "minimum": 1,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "paragraph_index": {
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "row_index": {
                "minimum": 1,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "sheet_name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "source_end": {
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "source_start": {
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "table_index": {
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "xml_path": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "page_number",
              "source_start",
              "source_end",
              "bbox"
            ],
            "type": "object"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "segment_id",
          "kind",
          "text",
          "canonical_start",
          "canonical_end",
          "source"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "source_media_type": {
      "minLength": 1,
      "type": "string"
    },
    "status": {
      "const": "PARSED"
    },
    "tables": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "column_count": {
            "minimum": 0,
            "type": "integer"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "row_count": {
            "minimum": 0,
            "type": "integer"
          },
          "rows": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "cells": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "cell_reference": {
                        "minLength": 1,
                        "type": "string"
                      },
                      "column_index": {
                        "minimum": 1,
                        "type": "integer"
                      },
                      "value": {
                        "type": [
                          "string",
                          "number",
                          "integer",
                          "boolean",
                          "null"
                        ]
                      },
                      "value_type": {
                        "enum": [
                          "STRING",
                          "INTEGER",
                          "NUMBER",
                          "BOOLEAN",
                          "DATE",
                          "DATETIME",
                          "FORMULA",
                          "EMPTY"
                        ]
                      }
                    },
                    "required": [
                      "column_index",
                      "cell_reference",
                      "value",
                      "value_type"
                    ],
                    "type": "object"
                  },
                  "type": "array"
                },
                "row_index": {
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "required": [
                "row_index",
                "cells"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "source_kind": {
            "enum": [
              "DOCX",
              "CSV",
              "TSV",
              "XLSX"
            ]
          },
          "table_id": {
            "pattern": "^table:[a-f0-9]{64}$",
            "type": "string"
          },
          "table_index": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "table_id",
          "source_kind",
          "name",
          "table_index",
          "row_count",
          "column_count",
          "rows"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "text": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "document_id",
    "artifact_id",
    "content_sha256",
    "source_media_type",
    "parser",
    "text",
    "segments",
    "pages",
    "ocr_assessment",
    "status",
    "tables"
  ],
  "title": "TrueColor Canonical Parsed Document",
  "type": "object"
}
