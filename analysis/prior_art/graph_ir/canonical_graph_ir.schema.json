{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truecolor.local/schemas/prior-art-graph-ir.schema.json",
  "title": "TrueColor Prior-Art Evidence Graph IR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "graph_id",
    "schema_version",
    "created_at",
    "source_manifest_sha256",
    "nodes",
    "edges"
  ],
  "properties": {
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "evidence_locator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "locator_type",
        "locator_value"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "locator_type": {
          "enum": [
            "PAGE",
            "SECTION",
            "PARAGRAPH",
            "FIGURE",
            "TABLE",
            "ABSTRACT",
            "METADATA",
            "API_RESPONSE",
            "CODE_LINE",
            "DATASET_ROW"
          ]
        },
        "locator_value": {
          "type": "string",
          "minLength": 1
        },
        "quoted_text": {
          "type": ["string", "null"]
        },
        "source_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "trust_measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "value",
        "basis",
        "assessed_by",
        "assessed_at"
      ],
      "properties": {
        "dimension": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": ["number", "null"],
          "minimum": 0.0,
          "maximum": 1.0
        },
        "basis": {
          "type": "string",
          "minLength": 1
        },
        "assessed_by": {
          "type": "string",
          "minLength": 1
        },
        "assessed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type",
        "label",
        "properties",
        "provenance",
        "trust"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "properties": {
          "type": "object"
        },
        "provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_locator"
          }
        },
        "trust": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/trust_measurement"
          }
        },
        "review_status": {
          "enum": [
            "UNREVIEWED",
            "MACHINE_REVIEWED",
            "HUMAN_REVIEWED",
            "DISPUTED",
            "SUPERSEDED"
          ]
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "edge_type",
        "source_node_id",
        "target_node_id",
        "properties",
        "provenance",
        "confidence",
        "review_status"
      ],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "edge_type": {
          "type": "string",
          "minLength": 1
        },
        "source_node_id": {
          "type": "string",
          "minLength": 1
        },
        "target_node_id": {
          "type": "string",
          "minLength": 1
        },
        "properties": {
          "type": "object"
        },
        "provenance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_locator"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "review_status": {
          "enum": [
            "UNREVIEWED",
            "MACHINE_REVIEWED",
            "HUMAN_REVIEWED",
            "DISPUTED",
            "SUPERSEDED"
          ]
        },
        "valid_from": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "valid_to": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  }
}
