{
  "$id": "https://truecolor.local/schemas/prior-art-source.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "allOf": [
    {
      "anyOf": [
        {
          "properties": {
            "identifier": {
              "properties": {
                "doi": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "doi"
              ]
            }
          }
        },
        {
          "properties": {
            "identifier": {
              "properties": {
                "pmid": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "pmid"
              ]
            }
          }
        },
        {
          "properties": {
            "identifier": {
              "properties": {
                "arxiv": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "arxiv"
              ]
            }
          }
        },
        {
          "properties": {
            "identifier": {
              "properties": {
                "official_document_id": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "official_document_id"
              ]
            }
          }
        },
        {
          "properties": {
            "url": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "url"
          ]
        }
      ]
    }
  ],
  "properties": {
    "authors": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "canonical_key": {
      "minLength": 1,
      "type": "string"
    },
    "claims_addressed": {
      "type": "array"
    },
    "datasets": {
      "type": "array"
    },
    "domains": {
      "minItems": 1,
      "type": "array"
    },
    "estimands": {
      "type": "array"
    },
    "evidence_tier": {
      "enum": [
        "TIER_1_PRIMARY_PEER_REVIEWED",
        "TIER_2_STANDARD_OR_OFFICIAL",
        "TIER_3_PRIMARY_PREPRINT",
        "TIER_4_PATENT",
        "TIER_5_SECONDARY"
      ]
    },
    "extraction_status": {
      "enum": [
        "IDENTIFIED",
        "SCREENED",
        "EXTRACTED",
        "SECOND_PASS_VALIDATED",
        "EXCLUDED"
      ]
    },
    "identifier": {
      "additionalProperties": false,
      "properties": {
        "arxiv": {
          "type": [
            "string",
            "null"
          ]
        },
        "doi": {
          "type": [
            "string",
            "null"
          ]
        },
        "isbn": {
          "type": [
            "string",
            "null"
          ]
        },
        "official_document_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "patent": {
          "type": [
            "string",
            "null"
          ]
        },
        "pmid": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "limitations": {
      "type": "array"
    },
    "methods": {
      "type": "array"
    },
    "primary_source": {
      "type": "boolean"
    },
    "publication_status": {
      "type": "string"
    },
    "retrieved_date": {
      "format": "date",
      "type": "string"
    },
    "source_id": {
      "pattern": "^PA-[0-9]{4}$",
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "technical_summary": {
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "type": "string"
    },
    "url": {
      "minLength": 1,
      "type": "string"
    },
    "year": {
      "maximum": 2026,
      "minimum": 1900,
      "type": "integer"
    }
  },
  "required": [
    "source_id",
    "title",
    "authors",
    "year",
    "source_type",
    "publication_status",
    "identifier",
    "url",
    "retrieved_date",
    "primary_source",
    "domains",
    "claims_addressed",
    "technical_summary",
    "methods",
    "datasets",
    "estimands",
    "limitations",
    "extraction_status",
    "canonical_key",
    "evidence_tier"
  ],
  "title": "TrueColor Prior-Art Source",
  "type": "object"
}
