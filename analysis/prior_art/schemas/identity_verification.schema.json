{
  "$id": "https://truecolor.local/schemas/identity-verification.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "harvested_title": {
            "maxLength": 0
          }
        },
        "required": [
          "harvested_title"
        ]
      },
      "then": {
        "properties": {
          "harvest_metadata_issues": {
            "contains": {
              "const": "MISSING_HARVESTED_TITLE"
            }
          }
        }
      }
    }
  ],
  "properties": {
    "authoritative_sources": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "evidence_sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "identifier_or_url": {
            "minLength": 1,
            "type": "string"
          },
          "retrieved_date": {
            "format": "date",
            "type": "string"
          },
          "source_type": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "source_type",
          "identifier_or_url",
          "retrieved_date",
          "evidence_sha256"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "candidate_key": {
      "minLength": 1,
      "type": "string"
    },
    "canonical_authors": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "canonical_identifier": {
      "additionalProperties": false,
      "properties": {
        "arxiv": {
          "type": [
            "string",
            "null"
          ]
        },
        "doi": {
          "type": [
            "string",
            "null"
          ]
        },
        "isbn": {
          "type": [
            "string",
            "null"
          ]
        },
        "official_document_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "patent": {
          "type": [
            "string",
            "null"
          ]
        },
        "pmcid": {
          "type": [
            "string",
            "null"
          ]
        },
        "pmid": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "canonical_title": {
      "type": [
        "string",
        "null"
      ]
    },
    "canonical_venue": {
      "type": [
        "string",
        "null"
      ]
    },
    "canonical_year": {
      "maximum": 2026,
      "minimum": 1900,
      "type": [
        "integer",
        "null"
      ]
    },
    "conflicts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "field": {
            "type": "string"
          },
          "observed_values": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "resolution": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "field",
          "observed_values",
          "resolution"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "global_rank": {
      "minimum": 1,
      "type": "integer"
    },
    "harvest_metadata_issues": {
      "items": {
        "enum": [
          "MISSING_HARVESTED_TITLE",
          "MISSING_HARVESTED_AUTHORS",
          "MISSING_HARVESTED_YEAR",
          "MISSING_HARVESTED_VENUE",
          "MISSING_CANONICAL_IDENTIFIER"
        ]
      },
      "type": "array",
      "uniqueItems": true
    },
    "harvested_title": {
      "type": "string"
    },
    "identity_checks": {
      "additionalProperties": false,
      "properties": {
        "authorship_matches": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "canonical_identifier_resolves": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "correction_or_retraction_status_resolved": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "duplicate_version_relationship_resolved": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "normalized_title_matches": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "publication_status_resolved": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "publication_type_resolved": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "publication_venue_matches": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "publication_year_matches": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "required": [
        "canonical_identifier_resolves",
        "normalized_title_matches",
        "publication_year_matches",
        "authorship_matches",
        "publication_venue_matches",
        "publication_type_resolved",
        "publication_status_resolved",
        "duplicate_version_relationship_resolved",
        "correction_or_retraction_status_resolved"
      ],
      "type": "object"
    },
    "publication_status": {
      "enum": [
        "PUBLISHED",
        "PREPRINT",
        "CONFERENCE_PROCEEDING",
        "STANDARD",
        "PATENT",
        "RETRACTED",
        "CORRECTED",
        "WITHDRAWN",
        "UNKNOWN"
      ]
    },
    "publication_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "related_candidate_keys": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "review_notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "reviewer": {
      "minLength": 1,
      "type": "string"
    },
    "verification_state": {
      "enum": [
        "UNVERIFIED",
        "VERIFIED",
        "CONFLICT",
        "UNRESOLVED",
        "DUPLICATE_VERSION",
        "RETRACTED",
        "CORRECTION_ONLY",
        "NON_SCHOLARLY"
      ]
    },
    "version_relationship": {
      "enum": [
        "CANONICAL_VERSION",
        "PREPRINT_OF_PUBLISHED_ARTICLE",
        "PUBLISHED_VERSION_OF_PREPRINT",
        "CONFERENCE_VERSION",
        "EXTENDED_JOURNAL_VERSION",
        "CORRECTION_OF",
        "RETRACTION_OF",
        "DUPLICATE_METADATA_RECORD",
        "UNRESOLVED"
      ]
    }
  },
  "required": [
    "candidate_key",
    "global_rank",
    "harvested_title",
    "harvest_metadata_issues",
    "verification_state",
    "canonical_identifier",
    "canonical_title",
    "canonical_authors",
    "canonical_year",
    "canonical_venue",
    "publication_type",
    "publication_status",
    "version_relationship",
    "related_candidate_keys",
    "identity_checks",
    "authoritative_sources",
    "conflicts",
    "reviewer",
    "review_notes"
  ],
  "title": "TrueColor Stage 1 Candidate Identity Verification",
  "type": "object"
}
